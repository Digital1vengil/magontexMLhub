{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.mjs\"",
            "timeout": 300,
            "statusMessage": "Guardrail (vite): verificando comando (push = tests + build primero)…"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-edits.mjs\"",
            "timeout": 30,
            "statusMessage": "Guardrail (vite): verificando edición…"
          }
        ]
      }
    ]
  }
}
